# ════════════════════════════════════════════════
#  AtomicBot - Railway Environment Variables
# ════════════════════════════════════════════════

# Obavezno - promijeni u produkciji!
JWT_SECRET=promijeni_ovo_u_neki_dugacki_random_string_32+znakova

# Free model stack (OpenRouter)
OPENROUTER_API_KEY=sk-or-...
FRONTEND_URL=https://atomicbot-production-1e32.up.railway.app

# (Opcionalno) Ako frontend i API nisu na istom domenu,
# postavi punu API bazu za Vite build (npr. https://api.example.com)
VITE_API_BASE=https://atomicbot-production-1e32.up.railway.app

# Single-user admin mode
SINGLE_USER_MODE=true
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-this-password

# Railway automatski postavlja PORT i RAILWAY_PUBLIC_DOMAIN
