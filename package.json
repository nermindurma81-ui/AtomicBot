{
  "name": "atomicbot",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "build": "cd frontend && npm install && npm run build",
    "start": "node server.js",
    "dev:api": "node --watch server.js",
    "dev:ui": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\""
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "better-sqlite3": "^9.4.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "uuid": "^9.0.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20 <22"
  }
}
